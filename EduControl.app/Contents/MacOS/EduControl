#!/usr/bin/env bash
# Resolve o diretГіrio raiz do projeto a partir de dentro do .app
APP_BUNDLE="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_DIR="$(dirname "$APP_BUNDLE")"
BACKEND="$PROJECT_DIR/backend"
FRONTEND="$PROJECT_DIR/frontend"

# Se jГЎ estiver rodando, sГі abre o navegador
if lsof -i :4200 -t &>/dev/null 2>&1; then
  open "http://localhost:4200"
  exit 0
fi

# NotificaГ§ГЈo de inГӯcio
osascript -e 'display notification "Iniciando servidoresвҖҰ" with title "EduControl рҹ“ҡ" subtitle "Aguarde alguns instantes"' 2>/dev/null || true

# Abre dois terminais: backend e frontend
osascript - "$BACKEND" "$FRONTEND" << 'EOF'
on run argv
  set backendDir  to item 1 of argv
  set frontendDir to item 2 of argv

  tell application "Terminal"
    activate

    -- Janela 1: Backend
    set w1 to do script "clear; printf '\\033[1;35mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\\n  рҹ“ҡ  EduControl вҖ” Backend  (porta 8080)\\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\\033[0m'; cd " & quoted form of backendDir & "; mvn spring-boot:run"

    -- Janela 2: Frontend (aguarda 20s para o backend subir)
    set w2 to do script "clear; printf '\\033[1;34mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\\n  рҹҺЁ  EduControl вҖ” Frontend  (porta 4200)\\n  Aguardando backend iniciarвҖҰ\\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\\033[0m'; cd " & quoted form of frontendDir & "; sleep 20 && ng serve --host 0.0.0.0 --open"

    -- Posiciona as janelas lado a lado
    try
      set bounds of w1 to {0, 23, 950, 500}
      set bounds of w2 to {960, 23, 1910, 500}
    end try
  end tell
end run
EOF
