#!/usr/bin/env bash
# EduControl — Lançador silencioso (sem terminal)
APP_BUNDLE="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_DIR="$(dirname "$APP_BUNDLE")"
BACKEND="$PROJECT_DIR/backend"
FRONTEND="$PROJECT_DIR/frontend"
LOG_DIR="$PROJECT_DIR/logs"

# Garante que os executáveis do Homebrew e sistema estejam disponíveis
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

mkdir -p "$LOG_DIR"

notify() {
  osascript -e "display notification \"$1\" with title \"EduControl 📚\"" 2>/dev/null || true
}

# Se frontend já estiver rodando, só abre o navegador
if lsof -i :4200 -t &>/dev/null 2>&1; then
  open "http://localhost:4200"
  exit 0
fi

notify "Iniciando EduControl…"

# Encerra processos antigos nas portas usadas
OLD_BACK=$(lsof -ti :8080 2>/dev/null); [ -n "$OLD_BACK"  ] && kill -9 $OLD_BACK  2>/dev/null && sleep 1
OLD_FRONT=$(lsof -ti :4200 2>/dev/null); [ -n "$OLD_FRONT" ] && kill -9 $OLD_FRONT 2>/dev/null && sleep 1

# ── Backend ───────────────────────────────────────────────────────────────
cd "$BACKEND"
nohup mvn spring-boot:run >> "$LOG_DIR/backend.log" 2>&1 &
BACK_PID=$!
disown $BACK_PID

# Aguarda backend responder (máx 90s)
notify "Aguardando backend…"
for i in $(seq 1 90); do
  curl -sf http://localhost:8080/api/subjects -o /dev/null 2>&1 && break
  sleep 1
done

# ── Frontend ──────────────────────────────────────────────────────────────
cd "$FRONTEND"
nohup ng serve --host 0.0.0.0 >> "$LOG_DIR/frontend.log" 2>&1 &
FRONT_PID=$!
disown $FRONT_PID

# Aguarda frontend compilar (máx 90s)
notify "Compilando frontend…"
for i in $(seq 1 90); do
  curl -sf http://localhost:4200 -o /dev/null 2>&1 && break
  sleep 1
done

# Salva PIDs para parar depois
echo "$BACK_PID $FRONT_PID" > "$PROJECT_DIR/.educontrol.pids"

notify "EduControl pronto! 🚀"
open "http://localhost:4200"
